{
    "require": {
        "php": "~7.4.0|~8.0.0|~8.1.0|~8.2.0"
    },
    "require-dev": {
        "glpi-project/tools": "^0.8"
    },
    "config": {
        "optimize-autoloader": true,
        "platform": {
            "php": "7.4"
        },
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit -c phpunit.xml",
        "phpstan": "phpstan analyse -c phpstan.neon"
    },
    "autoload-dev": {
        "psr-4": {
            "Glpi\\Tools\\": "../../tools/src/"
        }
    }
}
